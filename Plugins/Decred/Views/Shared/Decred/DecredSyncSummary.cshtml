@using BTCPayServer.Plugins.Decred.Services
@inject DecredRpcProvider RpcProvider

@foreach (var cryptoCode in RpcProvider.GetCryptoCodes())
{
    var summary = RpcProvider.GetSummary(cryptoCode);
    <div class="d-flex align-items-center gap-2">
        <span class="badge @(summary is { WalletAvailable: true, Synced: true } ? "bg-success" : "bg-warning")">
            @cryptoCode
        </span>
        @if (summary == null || !summary.WalletAvailable)
        {
            <span class="text-danger">Wallet unavailable</span>
        }
        else if (!summary.Synced)
        {
            <span class="text-warning">Syncing... @summary.WalletHeight</span>
        }
        else
        {
            <span class="text-success">Synced at @summary.WalletHeight</span>
        }
    </div>
}
