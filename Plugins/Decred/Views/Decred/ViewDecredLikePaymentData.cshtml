@using BTCPayServer.Payments
@using BTCPayServer.Plugins.Decred.Payments
@using BTCPayServer.Services.Invoices
@model IEnumerable<BTCPayServer.Services.Invoices.PaymentEntity>

@{
    var pmi = PaymentTypes.CHAIN.GetPaymentMethodId("DCR");
    var payments = Model.Where(p => p.PaymentMethodId == pmi).ToList();
    if (!payments.Any()) return;
}

@foreach (var payment in payments)
{
    var data = payment.Details?.ToObject<DecredLikePaymentData>();
    if (data == null) continue;

    <div class="transaction-info">
        <span class="badge bg-info">DCR</span>
        <span>@payment.Value DCR</span>
        @if (!string.IsNullOrEmpty(data.TransactionId))
        {
            <a href="https://dcrdata.decred.org/tx/@data.TransactionId"
               target="_blank" rel="noreferrer noopener"
               class="text-break">@data.TransactionId</a>
        }
        <span class="text-muted">(@data.ConfirmationCount confirmations)</span>
    </div>
}
